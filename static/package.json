{
  "name": "samgis-fe",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && vite build && pnpm tailwindcss -i src/input.css -o dist/output.css",
    "preview": "vite preview --port 5173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:html_report": "vitest run --coverage && vite preview --outDir coverage",
    "test:mutate": "stryker run",
    "test:e2e": "playwright test --workers 1",
    "test:e2e:smoke": "SMOKE_URL=http://localhost:7860 playwright test e2e/samgis-be-docker-smoke.spec.ts --workers 1",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-pattern .gitignore",
    "build:tailwindcss": "pnpm dlx @tailwindcss/cli -i src/input.css -o dist/output.css"
  },
  "type": "module",
  "dependencies": {
    "@geoman-io/leaflet-geoman-free": "^2.19.3",
    "driver.js": "^1.4.0",
    "leaflet": "^1.9.4",
    "leaflet-providers": "^3.0.0",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/cli": "^4.3.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.4",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "snyk"
    ],
    "onlyBuiltDependencies": [
      "snyk"
    ],
    "overrides": {
      "minimatch": ">=10.2.3",
      "rollup": ">=4.59.0",
      "ajv": ">=8.18.0",
      "eslint>ajv": "^6.14.0",
      "esbuild": "^0.28.1",
      "flatted": ">=3.4.2",
      "fast-uri": ">=3.1.2",
      "postcss": ">=8.5.10",
      "js-cookie": ">=3.0.7",
      "brace-expansion": ">=5.0.6",
      "qs": ">=6.15.2"
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
